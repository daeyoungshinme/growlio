    "axios": "^1.16.1",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.390.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
