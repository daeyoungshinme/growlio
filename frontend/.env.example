# Supabase (supabase.com > Project Settings > API)
VITE_SUPABASE_URL=https://xyzabc.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# 이메일 인증 후 리다이렉트 URL (Supabase Dashboard > Authentication > URL Configuration의 Site URL과 일치)
VITE_REDIRECT_URL=https://yourdomain.com

# API 서버 도메인 (vite.config.ts 프록시 설정용 — 개발 시 localhost:8000, 프로덕션 시 실제 도메인)
VITE_API_DOMAIN=localhost:8000

# Sentry 에러 추적 (비워두면 비활성화 — sentry.io에서 DSN 발급)
VITE_SENTRY_DSN=
