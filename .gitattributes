# Auto detect text files and normalize line endings to LF
* text=auto

*.py    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf
*.conf  text eol=lf
*.sql   text eol=lf
*.html  text eol=lf
*.css   text eol=lf

# Binary files
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.otf   binary
*.pdf   binary
*.zip   binary
*.apk   binary
