# App
APP_SECRET_KEY=your-random-64-char-hex-secret-key-here
APP_ENV=development

# Database (overridden in docker-compose for container)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/growlio

# Redis
REDIS_URL=redis://localhost:6379/0

# KIS Credential Encryption Key (32 bytes hex)
KIS_CRED_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# DART OpenAPI (opendart.fss.or.kr)
DART_API_KEY=your-dart-api-key-here

# 오픈뱅킹 (Open Banking)
OPEN_BANKING_CLIENT_ID=
OPEN_BANKING_CLIENT_SECRET=
OPEN_BANKING_REDIRECT_URI=http://localhost:8000/api/v1/open-banking/callback
OPEN_BANKING_BASE_URL=https://testapi.openbanking.or.kr
