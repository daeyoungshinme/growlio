# App
APP_SECRET_KEY=your-random-64-char-hex-secret-key-here
APP_ENV=development

# Database
POSTGRES_PASSWORD=your-postgres-password-here
DATABASE_URL=postgresql+asyncpg://postgres:your-postgres-password-here@localhost:5432/growlio

# Redis
REDIS_URL=redis://localhost:6379/0

# KIS Credential Encryption Key (32 bytes hex)
KIS_CRED_ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# JWT
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# DART OpenAPI (opendart.fss.or.kr)
DART_API_KEY=your-dart-api-key-here
